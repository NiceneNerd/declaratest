<Window x:Class="Declaratest.Gui.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
        mc:Ignorable="d"
        Title="Declaratest GUI"
        Height="720"
        Width="1200"
        MinWidth="960"
        MinHeight="640">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" Command="{Binding NewCommand}" InputGestureText="Ctrl+N" />
                <MenuItem Header="_Open..." Command="{Binding OpenCommand}" InputGestureText="Ctrl+O" />
                <Separator />
                <MenuItem Header="_Save" Command="{Binding SaveCommand}" InputGestureText="Ctrl+S" />
                <MenuItem Header="Save _As..." Command="{Binding SaveAsCommand}" InputGestureText="Ctrl+Shift+S" />
                <Separator />
                <MenuItem Header="_Export to DOCX" Command="{Binding GeneratePreviewCommand}" InputGestureText="Ctrl+E" />
                <Separator />
                <MenuItem Header="E_xit" Command="ApplicationCommands.Close" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Command="ApplicationCommands.Undo" InputGestureText="Ctrl+Z" />
                <MenuItem Header="_Redo" Command="ApplicationCommands.Redo" InputGestureText="Ctrl+Y" />
                <Separator />
                <MenuItem Header="_Find" Command="ApplicationCommands.Find" InputGestureText="Ctrl+F" />
                <MenuItem Header="_Replace" InputGestureText="Ctrl+H" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Toggle Preview" Command="{Binding TogglePreviewCommand}" InputGestureText="F5" />
                <MenuItem Header="_Zoom 100%" Command="{Binding ResetZoomCommand}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About Declaratest" Command="{Binding ShowAboutCommand}" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem Content="{Binding StatusMessage}" />
            <Separator />
            <StatusBarItem Content="{Binding PreviewStatus}" />
        </StatusBar>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <ToolBar Grid.ColumnSpan="3">
                <Button Content="New" Command="{Binding NewCommand}" />
                <Button Content="Open" Command="{Binding OpenCommand}" />
                <Separator />
                <Button Content="Generate DOCX" Command="{Binding GeneratePreviewCommand}" />
                <Button Content="Save" Command="{Binding SaveCommand}" />
            </ToolBar>

            <avalonEdit:TextEditor Grid.Row="1"
                                   Grid.Column="0"
                                   Margin="8"
                                   ShowLineNumbers="True"
                                   FontFamily="Consolas"
                                   FontSize="14"
                                   Text="{Binding DocumentText, UpdateSourceTrigger=PropertyChanged}"
                                   HorizontalScrollBarVisibility="Auto"
                                   VerticalScrollBarVisibility="Auto" />

            <GridSplitter Grid.Row="1"
                          Grid.Column="1"
                          Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          Width="5" />

            <Grid Grid.Row="1" Grid.Column="2" Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                    <TextBlock DockPanel.Dock="Left"
                               Text="DOCX Preview"
                               FontWeight="Bold"
                               VerticalAlignment="Center" />
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding PreviewMessage}"
                               Foreground="Gray"
                               VerticalAlignment="Center" />
                </DockPanel>

                <Border Grid.Row="1" BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" BorderThickness="1">
                    <wfi:WindowsFormsHost x:Name="PreviewHost" Background="White" />
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
